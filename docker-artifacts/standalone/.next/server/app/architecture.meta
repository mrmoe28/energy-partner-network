{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/architecture/layout,_N_T_/architecture/page,_N_T_/architecture"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/architecture/__PAGE__",
    "/architecture",
    "/_index",
    "/_head"
  ]
}